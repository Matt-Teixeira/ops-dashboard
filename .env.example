# ops-dashboard — copy to .env and fill in (.env is gitignored).
# Mirrors the suite's PG env convention (see docs/infra-conventions.md).

APP_NAME=ops-dashboard

# --- HTTP server ---
PORT=8080

# --- PostgreSQL (read-only over util.app_run_logs) ---
# In-network the DB is reachable at pg_db:5432. From the host it's localhost:5432.
# Connect as the dedicated least-privilege role, NOT a superuser. Create it once
# with db/setup-readonly-role.sql (it has only CONNECT + USAGE + SELECT).
PGHOST=pg_db
PGPORT=5432
PGUSER=ops_dashboard_ro
PGPASSWORD=__set_me__
PGDATABASE=staging
PG_SSLMODE=require                       # disable | require | verify-full
PG_SSL_PATH=/opt/resources/ssl/pg_ssl.crt

# --- Dashboard tuning ---
# How far back the job grid / error feed look (partition-pruned on inserted_at).
GRID_LOOKBACK_DAYS=7
ERRORS_LOOKBACK_DAYS=2
# The grid query is heavy (detoasts JSON blobs), so it runs on a background
# interval and is served from a cached snapshot. How often to refresh, in ms.
GRID_REFRESH_MS=120000

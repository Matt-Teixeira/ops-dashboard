# ops-dashboard — copy to .env and fill in (.env is gitignored).
# Mirrors the suite's PG env convention (see docs/infra-conventions.md).

APP_NAME=ops-dashboard

# --- HTTP server ---
PORT=8080

# --- PostgreSQL (read-only over util.app_run_logs) ---
# In-network the DB is reachable at pg_db:5432. From the host it's localhost:5432.
# Connect as the dedicated least-privilege role, NOT a superuser. Create it once
# with db/setup-readonly-role.sql (it has only CONNECT + USAGE + SELECT).
PGHOST=pg_db
PGPORT=5432
PGUSER=ops_dashboard_ro
PGPASSWORD=__set_me__
PGDATABASE=staging
PG_SSLMODE=require                       # disable | require | verify-full
PG_SSL_PATH=/opt/resources/ssl/pg_ssl.crt

# --- Dashboard tuning ---
# Error-feed lookback window, in days (partition-pruned on inserted_at).
ERRORS_LOOKBACK_DAYS=2
# Job grid: served from an in-process incremental cache. A job is shown iff its
# last run is within the retention window (dormant jobs stay visible as stale
# within it, then age out). The grid bootstraps once over this window on boot,
# then ticks incrementally every GRID_REFRESH_MS, re-scanning SUMMARY_OVERLAP_MS
# behind the watermark each tick to absorb insert-lag skew. Every
# SUMMARY_RECONCILE_MS a tick instead does a full retention re-scan, so any
# late/backfilled insert older than the overlap is still picked up.
SUMMARY_RETENTION_DAYS=30
SUMMARY_OVERLAP_MS=300000
SUMMARY_RECONCILE_MS=21600000
GRID_REFRESH_MS=120000
